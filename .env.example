# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://nexus:nexus_secret@localhost:5432/nexus_wellness
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_secret
POSTGRES_DB=nexus_wellness

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Nexus AI ───────────────────────────────────────────────
NEXUS_API_KEY=your-nexus-api-key
NEXUS_API_BASE_URL=https://api.nexus-ai.example.com/v1
NEXUS_MODEL=nexus-core-v1

# ─── External APIs ──────────────────────────────────────────
# Nutritional data (e.g. USDA FoodData Central)
USDA_API_KEY=your-usda-api-key
USDA_API_BASE_URL=https://api.nal.usda.gov/fdc/v1

# Astrology / Ephemeris
ASTROLOGY_API_KEY=your-astrology-api-key
ASTROLOGY_API_BASE_URL=https://api.astrology-engine.example.com/v1

# ─── Storage ────────────────────────────────────────────────
STORAGE_BACKEND=local          # local | s3 | gcs
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=nexus-wellness-media
AWS_REGION=us-east-1

# ─── App ────────────────────────────────────────────────────
ENVIRONMENT=development        # development | staging | production
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
